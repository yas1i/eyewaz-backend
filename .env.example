# EYEWAZ backend configuration — copy to `.env` and fill in.
# The real .env is gitignored; never commit secrets.

# ---------------------------------------------------------------------------
# Database (local MongoDB for dev; use an Atlas SRV URI in production)
# ---------------------------------------------------------------------------
MONGO_URI="mongodb://localhost:27017/eyewaz"

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------
ENV="local"
STATIC_DIR="templates/"
JWT_SECRET_KEY="change-me-to-a-long-random-string"
FLASK_SECRET_KEY="change-me-to-a-long-random-string"

# Base URL that stored files/audio are served from (/files/<name>).
# iOS simulator: http://localhost:4242
# Physical device on LAN: http://<your-mac-ip>:4242
# Deployed: https://your-domain
PUBLIC_BASE_URL="http://localhost:4242"

# ---------------------------------------------------------------------------
# Azure AI services (OCR + English→Urdu translation + Urdu text-to-speech)
#
# Simplest setup: create ONE "Azure AI services" multi-service resource in the
# Azure portal. Its single key + region works for all three below; only the
# Vision endpoint is resource-specific.
# ---------------------------------------------------------------------------
REGION="eastus"

# Vision (OCR / Read API)
VISION_KEY="your-azure-ai-key"
VISION_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"

# Translator (text). The endpoint is the global Translator host.
TRANSLATION_KEY="your-azure-ai-key"
TEXT_TRANSLATION_ENDPOINT="https://api.cognitive.microsofttranslator.com/"
# Optional document-translation endpoint (not required for the text path).
DOCUMENT_TRANSLATION_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"

# Speech (text-to-speech). Uses REGION + this key.
SPEECH_KEY="your-azure-ai-key"
SPEECH_ENDPOINt="https://eastus.api.cognitive.microsoft.com/sts/v1.0/issuetoken"

# ---------------------------------------------------------------------------
# Deprecated: Azure Blob Storage (replaced by local filesystem in storage.py).
# Only needed if you switch back to Azure Blob.
# ---------------------------------------------------------------------------
# AZURE_ACCOUNT_NAME=""
# AZURE_CONTAINER=""
# AZURE_ACCOUNT_KEY=""
# AZURE_CONNECTION_STRING=""
